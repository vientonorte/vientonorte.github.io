{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vientonorte.github.io/schema/projects.schema.json",
  "title": "Dashboard Projects Manifest",
  "description": "Esquema Draft-07 para data/projects.json — metadatos bilingües del dashboard vientonorte.",
  "type": "object",
  "required": ["meta", "projects"],
  "additionalProperties": false,
  "definitions": {
    "bilingualString": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["es", "en"],
          "properties": {
            "es": { "type": "string" },
            "en": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "statDot": {
      "type": "string",
      "enum": ["live", "private", "off", "deprecated", "sprint"]
    },
    "badgeType": {
      "type": "string",
      "enum": ["live", "private", "repo", "deprecated"]
    },
    "linkIcon": {
      "type": "string",
      "enum": ["site", "github"]
    },
    "link": {
      "type": "object",
      "required": ["label", "href"],
      "additionalProperties": false,
      "properties": {
        "label": { "$ref": "#/definitions/bilingualString" },
        "href": {
          "type": "string",
          "pattern": "^https?://"
        },
        "icon": { "$ref": "#/definitions/linkIcon" },
        "requiresAuth": { "type": "boolean" }
      }
    },
    "stat": {
      "type": "object",
      "required": ["dot", "value", "label"],
      "additionalProperties": false,
      "properties": {
        "dot": { "$ref": "#/definitions/statDot" },
        "value": { "type": "string" },
        "label": { "$ref": "#/definitions/bilingualString" }
      }
    },
    "project": {
      "type": "object",
      "required": ["id", "title", "badge", "desc", "tags", "links"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
        },
        "title": { "$ref": "#/definitions/bilingualString" },
        "badge": { "$ref": "#/definitions/badgeType" },
        "desc": { "$ref": "#/definitions/bilingualString" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "links": {
          "type": "array",
          "items": { "$ref": "#/definitions/link" },
          "minItems": 1
        },
        "requiresAuth": { "type": "boolean" },
        "deprecated": { "type": "boolean" }
      }
    }
  },
  "properties": {
    "meta": {
      "type": "object",
      "required": ["name", "role", "contact", "stats"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "role": { "$ref": "#/definitions/bilingualString" },
        "contact": {
          "type": "object",
          "required": ["github", "linkedin"],
          "additionalProperties": false,
          "properties": {
            "github": { "type": "string", "pattern": "^https?://" },
            "linkedin": { "type": "string", "pattern": "^https?://" }
          }
        },
        "stats": {
          "type": "array",
          "items": { "$ref": "#/definitions/stat" },
          "minItems": 1
        }
      }
    },
    "projects": {
      "type": "array",
      "items": { "$ref": "#/definitions/project" },
      "minItems": 1
    }
  }
}
