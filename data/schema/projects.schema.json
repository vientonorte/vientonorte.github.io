{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vientonorte.github.io/schema/projects.schema.json",
  "title": "Dashboard de Proyectos",
  "description": "Esquema Draft-07 para data/projects.json — metadatos bilingües del dashboard.",
  "type": "object",
  "required": ["meta", "projects"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["name", "role", "contact", "stats"],
      "properties": {
        "name": { "type": "string" },
        "role": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "required": ["es", "en"],
              "properties": {
                "es": { "type": "string" },
                "en": { "type": "string" }
              },
              "additionalProperties": false
            }
          ]
        },
        "contact": {
          "type": "object",
          "properties": {
            "github": { "type": "string" },
            "linkedin": { "type": "string" }
          },
          "additionalProperties": false
        },
        "stats": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["dot", "value", "label"],
            "properties": {
              "dot": {
                "type": "string",
                "enum": ["live", "private", "off", "deprecated", "sprint"]
              },
              "value": { "type": "string" },
              "label": {
                "oneOf": [
                  { "type": "string" },
                  {
                    "type": "object",
                    "required": ["es", "en"],
                    "properties": {
                      "es": { "type": "string" },
                      "en": { "type": "string" }
                    },
                    "additionalProperties": false
                  }
                ]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "badge", "desc", "tags", "links"],
        "properties": {
          "id": { "type": "string" },
          "title": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["es", "en"],
                "properties": {
                  "es": { "type": "string" },
                  "en": { "type": "string" }
                },
                "additionalProperties": false
              }
            ]
          },
          "badge": {
            "type": "string",
            "enum": ["live", "private", "repo", "deprecated"]
          },
          "requiresAuth": { "type": "boolean" },
          "deprecated": { "type": "boolean" },
          "desc": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["es", "en"],
                "properties": {
                  "es": { "type": "string" },
                  "en": { "type": "string" }
                },
                "additionalProperties": false
              }
            ]
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label", "href"],
              "properties": {
                "label": {
                  "oneOf": [
                    { "type": "string" },
                    {
                      "type": "object",
                      "required": ["es", "en"],
                      "properties": {
                        "es": { "type": "string" },
                        "en": { "type": "string" }
                      },
                      "additionalProperties": false
                    }
                  ]
                },
                "href": { "type": "string" },
                "icon": { "type": "string" },
                "requiresAuth": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
